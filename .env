## Copy to .env (optional) to override defaults.

# SQL Server SA password (must meet complexity requirements)
SA_PASSWORD=PfeNet!2026Strong

# RabbitMQ credentials (do not use guest for containers)
RABBITMQ_USER=pfe
RABBITMQ_PASS=PfeNetRabbit!2026

# JWT settings (AuthService and ReclamationService must match)
JWT_ISSUER=AuthService
JWT_AUDIENCE=AuthServiceUsers
JWT_SECRET=ChangeThisJwtSecretKey_AtLeast32Chars

# NotificationService
NOTIFICATIONS_ADMIN_EMAIL=admin@local
