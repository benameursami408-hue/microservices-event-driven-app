# Copy this file to .env before running Docker Compose.
# Keep .env local. Do not commit real secrets.

# Public local ports
GATEWAY_HTTP_PORT=5005
FRONTEND_HTTP_PORT=5173

# SQL Server
# Must satisfy SQL Server password complexity requirements.
SA_PASSWORD=PfeNet!2026Strong

# RabbitMQ
RABBITMQ_USER=pfe
RABBITMQ_PASS=PfeNetRabbit!2026

# JWT settings. The same values must be used by every backend service.
JWT_ISSUER=AuthService
JWT_AUDIENCE=AuthServiceUsers
JWT_SECRET=PfeNet_Local_Development_Jwt_Secret_2026_Minimum_32_Chars

# NotificationService
NOTIFICATIONS_ADMIN_EMAIL=admin@savpro.local

# AuthService seeding, development only.
SEED_ENABLED=true
SEED_ADMIN_EMAIL=admin@savpro.local
SEED_ADMIN_PASSWORD=Password123!
SEED_ADMIN_FIRSTNAME=Admin
SEED_ADMIN_LASTNAME=User
SEED_ADMIN_PHONE=0000000000

# Security throttling. Lower these if you expose the demo outside localhost.
AUTH_RATE_LIMIT_PER_MINUTE=10
UPLOAD_RATE_LIMIT_PER_MINUTE=20
