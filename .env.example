## Copy to .env to override defaults (do not commit real secrets)

# SQL Server SA password (must meet SQL Server complexity requirements)
SA_PASSWORD=ChangeMe_123!Strong

# RabbitMQ credentials
RABBITMQ_USER=pfe
RABBITMQ_PASS=ChangeMe_Rabbit_123!

# JWT settings (AuthService and other services must match)
JWT_ISSUER=AuthService
JWT_AUDIENCE=AuthServiceUsers
JWT_SECRET=ChangeThisJwtSecretKey_AtLeast32Chars

# NotificationService
NOTIFICATIONS_ADMIN_EMAIL=admin@local
